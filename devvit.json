{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "hvacbot",
  "settings": {
    "subreddit": {
      "verifiedEnabled": {
        "type": "boolean",
        "label": "Restrict posts to verified users?"
      },
      "verifiedKarma": {
        "type": "number",
        "label": "Minimum post karma to override verification, set to 0 to disable.",
        "defaultValue": 100
      }
    }
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "height": "regular",
        "entry": "splash.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "hvacbot",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "hvacbot_dev"
  }
}
